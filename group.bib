%%
%% Entry types: @postdoc, @gradprimary, @gradproject, @undergrad
%%
%% Fields:
%%   name        = {Display Name}              (required)
%%   start       = {YYYY}                      (required)
%%   end         = {YYYY}                      (omit if current)
%%   department  = {Department, Institution}
%%   degree      = {PhD or MS}
%%   grad_year   = {YYYY}                      (year degree conferred)
%%   grad_inst   = {Institution}               (where degree was earned)
%%   title       = {Special title or role}
%%   now         = {Current position}
%%   photo       = {filename.jpg}              (in images/)
%%   questions   = {sliding, deform, fracture, stabilize, serve}
%%   methods     = {sar, theory, compute, ml, field, lab}
%%   program     = {UROP or MSRP or Project}   (undergrads only)
%%   note        = {Any extra info}
%% ============================================================


